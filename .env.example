# ============================================================
# 90 Days Challenge — Environment Variables
# Copy this file to .env for local development
# Set these in Netlify: Site Settings → Environment Variables
# ============================================================

# ── Supabase (client-side — safe to expose) ──────────────────
# VITE_ prefix is required for Vite to inject into the browser bundle
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_KEY=your_supabase_anon_publishable_key

# ── Supabase (server-side — NEVER expose to browser) ─────────
# Used only in netlify/functions/*.js
# Must be the SERVICE ROLE key, not the anon key
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# ── VAPID / Web Push ──────────────────────────────────────────
# Generate with: npx web-push generate-vapid-keys
# VITE_VAPID_PUBLIC_KEY is bundled into the browser (safe — it's public)
VITE_VAPID_PUBLIC_KEY=your_vapid_public_key
# Server-only — used in netlify/functions/send-push.js, admin-send-push.js, scheduled-push.js
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_EMAIL=mailto:admin@90dayschallenge.co.bw

# ── Email (Resend) ────────────────────────────────────────────
# Get API key from resend.com dashboard
# Domain must be verified in Resend before emails will deliver
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=Osi — 90 Days Challenge <noreply@90dayschallenge.co.bw>

# ── App URL ───────────────────────────────────────────────────
# Used in email templates and CORS origin checks
# On Netlify: set this to your actual domain
APP_URL=https://90dayschallenge.co.bw
